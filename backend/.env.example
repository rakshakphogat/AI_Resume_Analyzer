PORT=5000
NODE_ENV=development
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/ai-resume-analyzer
JWT_SECRET=replace_with_secure_jwt_secret
JWT_EXPIRES_IN=7d

# AI provider: groq (free tier), openai, or mock
AI_PROVIDER=groq
GROQ_API_KEY=replace_with_groq_api_key
GROQ_MODEL=llama-3.1-8b-instant
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

CLIENT_URL=http://localhost:5173

# Password reset email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@airesumeanalyzer.com
RESET_TOKEN_EXPIRES_MINUTES=20

# Google OAuth
GOOGLE_CLIENT_ID=

USE_CLOUDINARY=false
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
